{
  "name": "launchlayer-hub",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "convex dev",
    "convex:deploy": "convex deploy",
    "test": "pnpm run test:unit && pnpm run test:convex",
    "test:unit": "tsx --test convex/lib/*.test.ts",
    "test:convex": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc -p convex/tsconfig.json --noEmit",
    "typecheck": "tsc -p convex/tsconfig.json --noEmit"
  },
  "dependencies": {
    "convex": "^1.42.1"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.1",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^26.1.1",
    "convex-test": "^0.0.54",
    "eslint": "^9.39.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.10"
  }
}
