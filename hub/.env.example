# Convex deployment env (set via Dashboard or `npx convex env set`).
# Copy to .env.local only for reference — do not commit real tokens.

# Required for production: Bearer token on POST /api/publish and POST /api/delete.
# Must match publish_token in ~/.config/launchlayer/hub.conf on client machines.
# Leave unset only with HUB_ALLOW_OPEN_PUBLISH=1 (local/dev). Fail-closed otherwise.
# HUB_PUBLISH_TOKEN=

# Explicit opt-in for unauthenticated publish/delete (local/dev only). Never set in prod.
# HUB_ALLOW_OPEN_PUBLISH=1

# Generate a token: openssl rand -hex 32
