# NVIDIA desktop — no forced power-mode overrides (competitive preset can enable those).
# Driver env knobs below apply for all NVIDIA desktop profiles.

# Multi-threaded driver command submission
__GL_THREADED_OPTIMIZATIONS=1

# Persistent shader disk cache
__GL_SHADER_DISK_CACHE=1
__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
__GL_MaxFramesAllowed=1
