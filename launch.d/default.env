# Global infrastructure defaults (not gameplay profile — see launch.d/presets/)
SHADER_CACHE_CHECK=1
SHADER_CACHE_MAX_GB=10
SHADER_CACHE_CHECK_INTERVAL_HOURS=24

COMPATDATA_CHECK=1
COMPATDATA_MAX_GB=50
COMPATDATA_TRIM=0

VM_MAX_MAP_COUNT_MIN=2147483642
VM_MAX_MAP_COUNT_FIX=0

VRAM_PREFLIGHT_MIN_MB=0
PIPEWIRE_LOW_LATENCY=0
LAUNCH_LOG_MAX_LINES=5000

# systemd --user units stopped when VRAM_HOGS=1 (space-separated)
VRAM_HOG_UNITS="hyprwhspr.service app-dev.lizardbyte.app.Sunshine.service"

# If vm.max_map_count stays at 262144 after sysctl --system, install:
#   sudo cp /mnt/games/config/elasticsearch.conf /etc/sysctl.d/ && sudo sysctl --system
