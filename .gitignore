# LaunchLayer — ignore user/local/generated data.
# Shipped in git: launch.d/ (layers + lists), share/launchlayer/, examples/, lib/, test/

# OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.settings/

# Secrets at repo root (not launch.d/*.env shipped layers)
.env
.env.*
!.env.example

# Runtime / launch state (live data: ~/.local/state/launchlayer/)
*.log
.state/
launchlayer-state/

# Script temp files
*.tmp
*.bak
*.orig
.launchlayer.tmp

# launch.d — shipped layers only (default, presets/, profiles/, *.txt)
# Per-game configs belong in GAMES_DIR, not here.
launch.d/local.env
launch.d/[0-9]*.env

# GAMES_DIR — per-game configs (default: ~/.local/share/launchlayer/games)
# Ignore when LAUNCHLAYER_GAMES_DIR points inside the repo.
/games/

# examples/games — tracked reference configs only
examples/games/*.env
!examples/games/2357570.env

# Pre share/ layout (do not re-add moved assets under old paths)
/config/
/systemd/
/completions/

# Config export / backup archives (also written to ~/launchlayer-backups by default)
launchlayer-backup-*.tar.gz
launchlayer-export-*.tar.gz
*.tar.gz
*.zip

# Deprecated entry points from pre-rename installs
steam-game-launch-settings.sh
steaml

# Test artifacts
test-results/
.bats-logs/

# Packaging / install scratch
dist/
