# Overwatch 2 (Steam AppID 2357570)
INCLUDE=presets/competitive.env

# Force latest DLSS preset at launch (CachyOS dlss-swapper):
# https://wiki.cachyos.org/configuration/gaming/#forcing-the-latest-dlss-preset
DLSS_SWAPPER=1
# Prefer either DLSS_SWAPPER or PROTON_DLSS_UPGRADE (not both):
# PROTON_DLSS_UPGRADE=1
# OVERRIDE_PROTON=proton-cachyos-slr
GAME_EXTRA_ARGS="-skipnewsscreen=true -skipintro -nolog -gc-max-time-slice=3"
UNSET_VARS="DXVK_ASYNC ENABLE_LAYER_MESA_ANTI_LAG VKD3D_CONFIG"
