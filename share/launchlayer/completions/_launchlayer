# zsh completion for launchlayer
# Install: add completions/ to fpath before compinit, e.g. in ~/.zshrc:
#   fpath=(/mnt/games/config/completions $fpath)
#   autoload -Uz compinit && compinit

_launchlayer() {
	local -a subcmds presets appids
	local script=$words[1]

	subcmds=(
		'--pause-vram-hogs:pause VRAM-heavy systemd units'
		'--resume-vram-hogs:resume paused VRAM-heavy units'
		'--cleanup-stale-launch:clean up after a stale launch session'
		'--status:show runtime and cache state'
		'--show-cpu-topology:show X3D CPU topology hints'
		'--detect-environment:show auto-detected platform state'
		'--detect-defaults:show recommended machine-local env settings'
		'--write-local-config:write launch.d/local.env from detection'
		'--doctor:full environment and config health check'
		'--tui:interactive game and config browser'
		'--setup:onboarding helper (completions, launch option)'
		'--completions:manage shell tab completions'
		'--list-games:list installed Steam games'
		'--init-appid:scaffold games/<AppID>.env'
		'--init-unconfigured:scaffold configs for unconfigured games'
		'--prune-uninstalled:remove configs for uninstalled games'
		'--export-config:pack launch.d configs into a tarball'
		'--backup-config:timestamped config backup'
		'--import-config:restore configs from tarball'
		'--prune-backups:remove oldest backup archives'
		'--run-scheduled-backup:backup then prune (timer hook)'
		'--backup-timer:install/manage backup timer'
		'--backup-prefs:manage backup preferences'
		'--tui-prefs:manage TUI preferences'
		'--paths:shader cache, compatdata, and install paths'
		'--show-config:show resolved config for an AppID'
		'--edit-appid:open per-game config in $EDITOR'
		'--validate-config:lint .env config files'
		'--scan-anticheat:scan for EAC/BattlEye titles'
		'--scan-detections:audit detection heuristics'
		'--cache-report:report shader/compatdata cache sizes'
		'--launch-stats:summarize launch.log'
		'--dry-run:print env and launch chain without running'
		'--help:show help'
		'-h:show help'
		'--version:show version'
		'-V:show version'
	)

	presets=(standard competitive lightweight native)

	_arguments -C \
		'1: :->subcmd' \
		'*::arg:->args'

	case $state in
		subcmd)
			_describe 'subcommand' subcmds
			;;
		args)
			case $line[1] in
				--status|--show-config|--edit-appid|--launch-stats)
					appids=("${(@f)$(
						"$script" --list-games --json 2>/dev/null \
							| sed -n 's/.*"appid":"\([0-9]*\)".*/\1/p'
					)}")
					_arguments '*:appid:($appids)'
					;;
				--init-appid)
					appids=("${(@f)$(
						"$script" --list-games --json 2>/dev/null \
							| sed -n 's/.*"appid":"\([0-9]*\)".*/\1/p'
					)}")
					_arguments \
						'1:appid:($appids)' \
						'2:preset:($presets)'
					;;
				--validate-config)
					appids=("${(@f)$(
						"$script" --list-games --json 2>/dev/null \
							| sed -n 's/.*"appid":"\([0-9]*\)".*/\1/p'
					)}")
					_arguments '*:target:(all default presets $appids)'
					;;
				--init-unconfigured)
					_arguments \
						'(--preset)*--preset[preset to apply]:preset:($presets)' \
						'(--dry-run)*--dry-run[print actions without writing files]' \
						'(--eac-only)*--eac-only[only anticheat titles]'
					;;
				--prune-uninstalled)
					_arguments \
						'(--dry-run)*--dry-run[print actions without deleting files]' \
						'(--yes)*--yes[delete orphan configs without prompting]' \
						'(--json)*--json[JSON output]'
					;;
				--export-config)
					_arguments \
						'(--output)*--output[output archive path]:path:' \
						'(--include-local)*--include-local[include launch.d/local.env]' \
						'(--no-profiles)*--no-profiles[exclude launch.d/profiles]' \
						'(--include-tui)*--include-tui[include TUI preferences]' \
						'(--json)*--json[JSON output]'
					;;
				--backup-config)
					_arguments \
						'(--output)*--output[output directory or archive path]:path:' \
						'(--exclude-local)*--exclude-local[exclude launch.d/local.env]' \
						'(--no-profiles)*--no-profiles[exclude launch.d/profiles]' \
						'(--include-tui)*--include-tui[include TUI preferences]' \
						'(--json)*--json[JSON output]'
					;;
				--import-config)
					_arguments \
						'1:archive:_files -g "*.(tar.gz|tgz|tar)"' \
						'(--dry-run)*--dry-run[preview import without writing files]' \
						'(--yes)*--yes[apply import]' \
						'(--merge)*--merge[skip existing files]' \
						'(--replace)*--replace[overwrite existing files]' \
						'(--exclude-local)*--exclude-local[skip launch.d/local.env]' \
						'(--no-profiles)*--no-profiles[skip launch.d/profiles]' \
						'(--include-tui)*--include-tui[import TUI preferences]' \
						'(--json)*--json[JSON output]'
					;;
				--prune-backups)
					_arguments \
						'(--dir)*--dir[backup directory]:path:_directories' \
						'(--keep)*--keep[keep newest N archives]:count:' \
						'(--dry-run)*--dry-run[preview without deleting]' \
						'(--json)*--json[JSON output]'
					;;
				--backup-timer)
					_arguments \
						'1:action:(install enable disable status reinstall)' \
						'(--dir)*--dir[backup directory]:path:_directories' \
						'(--keep)*--keep[keep newest N archives]:count:' \
						'(--schedule)*--schedule[systemd OnCalendar expression]:calendar:' \
						'(--no-enable)*--no-enable[install without enabling timer]'
					;;
				--backup-prefs)
					_arguments \
						'1:action:(show reset set set-schedule)' \
						'(--json)*--json[JSON output]' \
						'(--reinstall-timer)*--reinstall-timer[reinstall systemd timer after reset]'
					;;
				--tui-prefs)
					_arguments \
						'1:action:(show reset set)' \
						'(--json)*--json[JSON output]'
					;;
				--list-games)
					_arguments \
						'(--configured)*--configured[only configured games]' \
						'(--json)*--json[JSON output]' \
						'(--grep)*--grep[filter by game name]:pattern:'
					;;
				--cache-report)
					_arguments \
						'(--min-gb)*--min-gb[minimum size in GB]:size:' \
						'(--shader-only)*--shader-only[shader caches only]' \
						'(--compat-only)*--compat-only[compatdata only]'
					;;
				--scan-anticheat)
					_arguments '(--update-list)*--update-list[update anticheat-appids.txt]'
					;;
				--completions)
					_arguments \
						'1:action:(status enable disable print)' \
						'(--shell)*--shell[shell to configure]:shell:(bash zsh fish nu pwsh osh all)'
					;;
			esac
			;;
	esac
}

if (( $+functions[compdef] )); then
	compdef _launchlayer \
		launchlayer \
		./launchlayer
	if [[ -n "${LAUNCHLAYER_CONFIG_DIR:-}" ]]; then
		compdef _launchlayer "$LAUNCHLAYER_CONFIG_DIR/launchlayer"
	fi
fi
